# Copy this to .env and fill in real values
DATABASE_URL=sqlite:///./domify.db
# For postgres use: postgresql+psycopg2://user:pass@localhost:5432/domify
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Comma-separated origins allowed to call the API with cookies
CORS_ORIGINS=http://localhost:5173,http://localhost:8000,https://domifyapp.onrender.com
# Set COOKIE_SECURE=true in production (HTTPS only)
COOKIE_SECURE=false
